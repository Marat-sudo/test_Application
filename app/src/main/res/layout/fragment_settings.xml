<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="ui.fragments.SettingsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/settingHeader"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="@color/colorPrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/settingUserPhoto"
            android:layout_width="@dimen/settings_user_photo_width"
            android:layout_height="@dimen/settings_user_photo_height"
            android:src="@drawable/sticker"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="@dimen/horizontal_margin"
            app:civ_border_color="@color/design_default_color_primary_dark"
            app:civ_border_width="@dimen/settings_user_photo_border" />
        
        <TextView
            android:id="@+id/settingUserFirstName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="@dimen/large_text"
            android:text="testing"
            android:layout_marginStart="@dimen/horizontal_margin"
            android:layout_marginTop="@dimen/vertical_margin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/settingUserPhoto"
            app:layout_constraintStart_toEndOf="@id/settingUserPhoto"/>

        <TextView
            android:id="@+id/settingUserPhone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="@dimen/normal_text_1"
            android:text="+7 xxx xxx xx xx"
            android:layout_marginStart="@dimen/horizontal_margin"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toBottomOf="@id/settingUserFirstName"
            app:layout_constraintStart_toEndOf="@id/settingUserPhoto"
            app:layout_constraintEnd_toEndOf="parent"/>
        <!-- тут не жалуется на @-->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/material_dynamic_primary40"
            android:textSize="12sp"
            android:text="userName"
            android:layout_marginStart="16dp"
            android:layout_marginTop="5dp"
            app:layout_constraintStart_toEndOf="@id/settingUserPhoto"
            app:layout_constraintTop_toBottomOf="@id/settingUserPhone"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>




</androidx.constraintlayout.widget.ConstraintLayout>